# AnnounceKit MCP server — environment variables
# Copy this file to `.env` and fill in the values.

# REQUIRED: your personal access token (create one in AnnounceKit → Settings → API Tokens).
# Works with any login method (Google, Microsoft, SAML, password).
ANNOUNCEKIT_TOKEN=

# OPTIONAL: which AnnounceKit instance to connect to.
# Defaults to production (https://announcekit.app/gq/v2) — leave unset for normal use.
# For LOCAL DEVELOPMENT against a local backend, set:
#   ANNOUNCEKIT_API_URL=http://localhost:3000
# ANNOUNCEKIT_API_URL=
# ANNOUNCEKIT_GRAPHQL_PATH=/gq/v2

# OPTIONAL (local/dev fallback only): email + password instead of a token.
# Does NOT work for SSO users — prefer a token.
# ANNOUNCEKIT_EMAIL=
# ANNOUNCEKIT_PASSWORD=
